{
  "id": "default",
  "version": "1.1.0",
  "name": "QA/Test Workflow",
  "summary": "Closed-loop workflow pack for QA artifacts with validation, review, supervisor approval, and artifact lifecycle gates.",
  "routes": {
    "source_inventory": {"description": "Build complete source inventory manifest.", "source_roles": ["source_root"], "prompt_intents": ["source_inventory"], "stages": ["source_inventory", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["source-manifest.yml", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "source_normalization": {"description": "Normalize source files into maintainable Markdown/profile artifacts.", "source_roles": ["source_manifest"], "prompt_intents": ["source_normalization"], "stages": ["source_normalization", "knowledge_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["normalization-report.json", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "secret_redaction": {"description": "Redact normalized knowledge before runtime use.", "source_roles": ["normalized_knowledge"], "prompt_intents": ["secret_redaction"], "stages": ["secret_redaction", "secret_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["redaction-report.yml", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "knowledge_validation": {"description": "Validate redacted runtime knowledge metadata, traceability, and no-secret state.", "source_roles": ["redacted_knowledge"], "prompt_intents": ["knowledge_validation"], "stages": ["knowledge_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["knowledge-validation-report.json", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "source_to_test_plan": {"description": "Generate a validated Test Plan from project, scope, and source baseline inputs.", "source_roles": ["source_manifest", "business_requirement", "api_spec", "ui_spec", "rsd", "pttk", "urd"], "prompt_intents": ["test_plan", "planning", "full_delivery"], "stages": ["test_plan", "test_plan_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["TestPlan.md", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "api_spec_to_test_design": {"description": "Generate API Test Design from API specification/source documents.", "source_roles": ["api_spec"], "prompt_intents": ["test_design", "api_test", "full_delivery"], "stages": ["api_operation_inventory", "api_td_setup_context", "api_td_method_header", "api_td_schema_validation", "api_td_business_logic", "api_td_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["API_OperationInventory.md", "API_TestDesign.md", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "api_spec_to_testcase": {"description": "Generate API Test Design and legacy 19-column manual test cases from API specification/source documents.", "source_roles": ["api_spec"], "prompt_intents": ["testcase", "manual_testcase", "excel_19_col", "full_delivery"], "stages": ["api_operation_inventory", "api_td_setup_context", "api_td_method_header", "api_td_schema_validation", "api_td_business_logic", "api_td_validation", "api_tc_from_td", "legacy_19col_export", "api_tc_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["API_OperationInventory.md", "API_TestDesign.md", "TestCaseSource.md", "Legacy19TestCase.generated.tsv", "Legacy19TestCase.generated.xlsx", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "api_test_design_to_testcase": {"description": "Generate legacy 19-column API test cases from an existing API Test Design.", "source_roles": ["api_test_design", "test_design"], "prompt_intents": ["testcase", "manual_testcase", "excel_19_col"], "stages": ["api_td_validation", "api_tc_from_td", "legacy_19col_export", "api_tc_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["TestCaseSource.md", "Legacy19TestCase.generated.tsv", "Legacy19TestCase.generated.xlsx", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "ui_source_to_test_design": {"description": "Generate UI Test Design from RSD/PTTK/UI source documents.", "source_roles": ["ui_spec", "rsd", "pttk"], "prompt_intents": ["test_design", "ui_test"], "stages": ["ui_td", "ui_td_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["UI_TestDesign.md", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "ui_source_to_testcase": {"description": "Generate UI Test Design and legacy 19-column manual test cases from UI/RSD/PTTK sources.", "source_roles": ["ui_spec", "rsd", "pttk"], "prompt_intents": ["testcase", "manual_testcase", "excel_19_col"], "stages": ["ui_td", "ui_td_validation", "ui_tc_from_td", "legacy_19col_export", "ui_tc_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["UI_TestDesign.md", "TestCaseSource.md", "Legacy19TestCase.generated.tsv", "Legacy19TestCase.generated.xlsx", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "ui_test_design_to_testcase": {"description": "Generate legacy 19-column UI test cases from an existing UI Test Design.", "source_roles": ["ui_test_design", "test_design"], "prompt_intents": ["testcase", "manual_testcase", "excel_19_col"], "stages": ["ui_td_validation", "ui_tc_from_td", "legacy_19col_export", "ui_tc_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["TestCaseSource.md", "Legacy19TestCase.generated.tsv", "Legacy19TestCase.generated.xlsx", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "urd_to_uat_testcase": {"description": "Generate business-facing UAT test cases from URD/RSD/business sources.", "source_roles": ["urd", "business_requirement", "rsd"], "prompt_intents": ["uat", "acceptance_test"], "stages": ["uat_tc", "uat_16col_export", "uat_tc_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["UAT_TestCaseSource.md", "UAT_TestCase.generated.tsv", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "testcase_to_api_automation": {"description": "Generate API automation support/Gherkin feature files from API test cases.", "source_roles": ["api_testcase", "legacy_testcase", "testcase"], "prompt_intents": ["automation_script", "gherkin", "api_test"], "stages": ["api_testcase_analysis", "api_method_header_feature", "api_schema_feature", "api_logic_business_feature", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["API_TestCase_Analysis.md", "api_method_header_validation.feature", "api_validation.feature", "api_logic_business.feature", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "api_spec_to_automation": {"description": "Generate API Test Design, API test cases, and Gherkin feature support from API specification/source documents.", "source_roles": ["api_spec"], "prompt_intents": ["automation_script", "gherkin"], "stages": ["api_operation_inventory", "api_td_setup_context", "api_td_method_header", "api_td_schema_validation", "api_td_business_logic", "api_td_validation", "api_tc_from_td", "legacy_19col_export", "api_tc_validation", "api_testcase_analysis", "api_method_header_feature", "api_schema_feature", "api_logic_business_feature", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["API_OperationInventory.md", "API_TestDesign.md", "TestCaseSource.md", "Legacy19TestCase.generated.tsv", "Legacy19TestCase.generated.xlsx", "API_TestCase_Analysis.md", "api_method_header_validation.feature", "api_validation.feature", "api_logic_business.feature", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "executed_workbook_to_execution": {"description": "Import manual execution results from an executed workbook, TSV, CSV, or Google Sheet.", "source_roles": ["executed_workbook", "manual_execution_result", "google_sheet_execution"], "prompt_intents": ["manual_execution", "execution_result"], "stages": ["manual_execution_reader", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["TestExecution.from-manual.tsv", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "executed_workbook_to_dashboard": {"description": "Import manual execution results and generate a Paygates dashboard/status summary.", "source_roles": ["executed_workbook", "manual_execution_result", "google_sheet_execution"], "prompt_intents": ["dashboard", "status", "paygates_summary"], "stages": ["manual_execution_reader", "paygates_dashboard", "tracker_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["TestExecution.from-manual.tsv", "PaygatesDashboard.generated.tsv", "PaygatesDashboard.generated.xlsx", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "testcase_to_dashboard": {"description": "Generate a Paygates dashboard from testcase and optional execution artifacts.", "source_roles": ["legacy_testcase", "testcase", "api_testcase", "ui_testcase"], "prompt_intents": ["dashboard", "status", "paygates_summary"], "stages": ["paygates_dashboard", "tracker_validation", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["PaygatesDashboard.generated.tsv", "PaygatesDashboard.generated.xlsx", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"},
    "coverage_audit": {"description": "Audit coverage across requirements, test design, test cases, execution, and automation artifacts.", "source_roles": ["api_spec", "ui_spec", "rsd", "pttk", "urd", "test_design", "testcase", "legacy_testcase"], "prompt_intents": ["coverage_audit", "gap_analysis", "review"], "stages": ["coverage_audit", "output_review", "supervisor_approval", "artifact_publish"], "final_outputs": ["CoverageMatrix.md", "GapAnalysis.md", "OutputReview.md", "SupervisorApproval.md"], "max_retries": 2, "draft_output_dir": "artifacts/default/draft", "reviewed_output_dir": "artifacts/default/reviewed", "approved_output_dir": "artifacts/default/approved", "failure_output_dir": "artifacts/default/rejected"}
  },
  "stages": {
    "source_inventory": {"kind": "tool", "outputs": ["source-manifest.yml"], "validators": ["source_manifest"]},
    "source_normalization": {"kind": "tool", "outputs": ["normalization-report.json"], "validators": ["normalized_knowledge"]},
    "secret_redaction": {"kind": "tool", "outputs": ["redaction-report.yml"], "validators": ["secret_redaction"]},
    "knowledge_validation": {"kind": "validation", "outputs": ["knowledge-validation-report.json"], "validators": ["normalized_knowledge", "secret_redaction"]},
    "test_plan": {"kind": "agent", "outputs": ["TestPlan.md"]},
    "test_plan_validation": {"kind": "validation", "outputs": ["TestPlan.validation.json"], "validators": ["test_plan_contract"]},
    "secret_validation": {"kind": "validation", "outputs": ["secret-validation-report.json"], "validators": ["secret_redaction"]},
    "api_operation_inventory": {"kind": "agent", "outputs": ["API_OperationInventory.md"]},
    "api_td_setup_context": {"kind": "prompt", "prompt": "prompts/API/API_TD_1_Setup_Context.txt", "outputs": ["API_TestDesign.md"]},
    "api_td_method_header": {"kind": "prompt", "prompt": "prompts/API/API_TD_2_Method_Header_BreakDown.txt", "outputs": ["API_TestDesign.md"]},
    "api_td_schema_validation": {"kind": "prompt", "prompt": "prompts/API/API_TD_3_Schema_Validation_BreakDown.txt", "outputs": ["API_TestDesign.md"]},
    "api_td_business_logic": {"kind": "prompt", "prompt": "prompts/API/API_TD_4_Value_Business_Cross_Logic_BreakDown.txt", "outputs": ["API_TestDesign.md"]},
    "api_td_validation": {"kind": "validation", "outputs": ["API_TestDesign.validation.json"], "validators": ["api_td_contract", "api_td_specificity"]},
    "api_tc_from_td": {"kind": "prompt", "prompt": "prompts/API/API_Gen_TC_From_TD_v2.txt", "outputs": ["TestCaseSource.md"]},
    "ui_td": {"kind": "prompt", "prompt": "prompts/UI/UI_Gen_TD.txt", "outputs": ["UI_TestDesign.md"]},
    "ui_td_validation": {"kind": "validation", "outputs": ["UI_TestDesign.validation.json"], "validators": ["ui_td_contract"]},
    "ui_tc_from_td": {"kind": "prompt", "prompt": "prompts/UI/UI_Gen_TC_From_TD.txt", "outputs": ["TestCaseSource.md"]},
    "uat_tc": {"kind": "prompt", "prompt": "prompts/UI/UI_Gen_TC_For_UAT.txt", "outputs": ["UAT_TestCaseSource.md"]},
    "legacy_19col_export": {"kind": "tool", "formatted_xlsx_required": true, "command_hint": "scripts/export_legacy_19col_xlsx.py", "outputs": ["Legacy19TestCase.generated.tsv", "Legacy19TestCase.generated.xlsx"], "validators": ["legacy_19col_tsv"]},
    "uat_16col_export": {"kind": "tool", "outputs": ["UAT_TestCase.generated.tsv"], "validators": ["uat_16col_tsv"]},
    "api_tc_validation": {"kind": "validation", "outputs": ["Legacy19TestCase.generated.tsv"], "validators": ["api_tc_specificity", "api_tc_granularity", "testcase_coverage_api"]},
    "ui_tc_validation": {"kind": "validation", "outputs": ["Legacy19TestCase.generated.tsv"], "validators": ["ui_tc_granularity", "testcase_coverage_ui"]},
    "uat_tc_validation": {"kind": "validation", "outputs": ["UAT_TestCase.validation.json"], "validators": ["uat_tc_granularity"]},
    "api_testcase_analysis": {"kind": "prompt", "prompt": "prompts/API/Gen Script/API_TestCase_Analysis.txt", "outputs": ["API_TestCase_Analysis.md"], "validators": ["api_automation_analysis_contract"]},
    "api_method_header_feature": {"kind": "prompt", "prompt": "prompts/API/Gen Script/API_Gen_Script_Method_Header_Validation_Feature.txt", "outputs": ["api_method_header_validation.feature"], "validators": ["api_automation_feature_contract"]},
    "api_schema_feature": {"kind": "prompt", "prompt": "prompts/API/Gen Script/API_Gen_Script_Validation_Feature.txt", "outputs": ["api_validation.feature"], "validators": ["api_automation_feature_contract"]},
    "api_logic_business_feature": {"kind": "prompt", "prompt": "prompts/API/Gen Script/API_Gen_Script_Logic_Business_Feature.txt", "outputs": ["api_logic_business.feature"], "validators": ["api_automation_feature_contract"]},
    "manual_execution_reader": {"kind": "tool", "outputs": ["TestExecution.from-manual.tsv"], "validators": ["execution_tsv"]},
    "paygates_dashboard": {"kind": "tool", "outputs": ["PaygatesDashboard.generated.tsv", "PaygatesDashboard.generated.xlsx"], "validators": ["paygates_dashboard_tsv"]},
    "tracker_validation": {"kind": "validation", "outputs": ["TrackerValidation.json"], "validators": ["tracker"]},
    "coverage_audit": {"kind": "agent", "outputs": ["CoverageMatrix.md", "GapAnalysis.md"]},
    "output_review": {"kind": "review", "outputs": ["OutputReview.md"], "validators": ["output_review_required"]},
    "supervisor_approval": {"kind": "approval", "outputs": ["SupervisorApproval.md"], "validators": ["supervisor_approval_required", "artifact_manifest"]},
    "artifact_publish": {"kind": "publish", "outputs": ["published-artifact-manifest.yml"], "validators": ["artifact_manifest"]}
  },
  "validators": {
    "source_manifest": "scripts/build_source_manifest.py",
    "normalized_knowledge": "scripts/validate_normalized_knowledge.py",
    "secret_redaction": "scripts/redact_secrets.py",
    "test_plan_contract": "scripts/validate_test_plan.py",
    "api_automation_analysis_contract": "scripts/validate_api_automation_analysis.py",
    "api_automation_feature_contract": "scripts/validate_api_automation_feature.py",
    "legacy_19col_tsv": "scripts/validate_legacy_19col_tsv.py",
    "uat_16col_tsv": "scripts/validate_testcase_contract.py --profile uat_16_column_testcase",
    "execution_tsv": "scripts/validate_output_contract.py --execution",
    "paygates_dashboard_tsv": "scripts/validate_paygates_dashboard.py",
    "api_td_contract": "scripts/validate_test_design.py --type api",
    "api_td_specificity": "scripts/validate_api_td_specificity.py",
    "api_tc_specificity": "scripts/validate_api_tc_specificity.py",
    "api_tc_granularity": "scripts/validate_testcase_granularity.py --profile api_legacy_19_column_testcase",
    "ui_tc_granularity": "scripts/validate_testcase_granularity.py --profile ui_legacy_19_column_testcase",
    "uat_tc_granularity": "scripts/validate_testcase_granularity.py --profile uat_16_column_testcase",
    "testcase_coverage_api": "scripts/validate_testcase_coverage.py --profile api_legacy_19_column_testcase",
    "testcase_coverage_ui": "scripts/validate_testcase_coverage.py --profile ui_legacy_19_column_testcase",
    "testcase_coverage_uat": "scripts/validate_testcase_coverage.py --profile uat_legacy_19_column_testcase",
    "testcase_coverage_data": "scripts/validate_testcase_coverage.py --profile data_legacy_19_column_testcase",
    "testcase_coverage_file_batch": "scripts/validate_testcase_coverage.py --profile file_batch_legacy_19_column_testcase",
    "ui_td_contract": "scripts/validate_test_design.py --type ui",
    "tracker": "scripts/validate_tracker.py",
    "artifact_manifest": "scripts/validate_artifact_manifest.py",
    "output_review_required": "review-gates.yml#output_review",
    "supervisor_approval_required": "review-gates.yml#supervisor_approval"
  }
}
